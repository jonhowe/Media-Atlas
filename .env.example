# Local development example.
# Copy to .env and pass it to uvicorn with: --env-file ../.env

MEDIA_ATLAS_HOST=127.0.0.1
MEDIA_ATLAS_PORT=8000

MEDIA_ATLAS_DATA_DIR=./data
MEDIA_ATLAS_REPORTS_DIR=./reports
MEDIA_ATLAS_LOGS_DIR=./logs
MEDIA_ATLAS_TRANSCODE_STAGING_DIR=./transcode-staging
MEDIA_ATLAS_TRANSCODE_BACKUP_DIR=./transcode-backups
MEDIA_ATLAS_ALLOWED_BROWSE_ROOTS=/Volumes,/mnt,/media

MEDIA_ATLAS_FFPROBE_PATH=ffprobe
MEDIA_ATLAS_FFMPEG_PATH=ffmpeg
MEDIA_ATLAS_SCAN_CONCURRENCY=2
MEDIA_ATLAS_FFPROBE_TIMEOUT_SECONDS=60
MEDIA_ATLAS_MARK_MISSING_FILES=true

MEDIA_ATLAS_FFMPEG_TIMEOUT_SECONDS=0
MEDIA_ATLAS_TRANSCODE_DURATION_TOLERANCE_SECONDS=3
MEDIA_ATLAS_TRANSCODE_DURATION_TOLERANCE_PERCENT=0.02

MEDIA_ATLAS_DIRECTORY_BROWSER_ENABLED=true

# Local development usually keeps auth disabled because the backend binds to loopback.
MEDIA_ATLAS_AUTH_MODE=disabled
MEDIA_ATLAS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000
MEDIA_ATLAS_TRANSCODE_MIN_FREE_BYTES=1073741824
MEDIA_ATLAS_LOG_RETENTION_DAYS=30
MEDIA_ATLAS_STAGED_OUTPUT_RETENTION_DAYS=0

# Optional Plex defaults. You can also configure Plex from the Settings page.
# MEDIA_ATLAS_PLEX_URL=http://127.0.0.1:32400
# MEDIA_ATLAS_PLEX_TOKEN=replace-with-plex-token

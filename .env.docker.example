# Production Docker Compose example.
# Copy this file to .env next to docker-compose.yml.

# Host port exposed by Docker.
MEDIA_ATLAS_PORT=8000
MEDIA_ATLAS_IMAGE=ghcr.io/jonhowe/media-atlas:latest

# Required: host media root mounted read-only into the container at /media.
MEDIA_ATLAS_MEDIA_ROOT=/mnt/media

# Production access control.
MEDIA_ATLAS_AUTH_MODE=single_admin
MEDIA_ATLAS_ADMIN_USERNAME=admin
MEDIA_ATLAS_ADMIN_PASSWORD=change-this-password
# Optional alternative to cleartext admin password:
# MEDIA_ATLAS_ADMIN_PASSWORD_HASH=pbkdf2_sha256$...
MEDIA_ATLAS_SESSION_SECRET=change-this-to-a-long-random-secret
MEDIA_ATLAS_SESSION_COOKIE_NAME=media_atlas_session
MEDIA_ATLAS_SESSION_COOKIE_SECURE=false
MEDIA_ATLAS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# Set true only when MEDIA_ATLAS_AUTH_MODE=disabled is intentional on a trusted LAN/VPN.
MEDIA_ATLAS_ACKNOWLEDGE_AUTH_DISABLED_LAN=false
MEDIA_ATLAS_FAIL_UNSAFE_BIND=false
# Reverse proxy auth mode only. The proxy must strip incoming copies before setting this header.
MEDIA_ATLAS_TRUSTED_USER_HEADER=X-Forwarded-User

# In-container roots available to the server-side directory browser.
# Use container paths, not host paths.
MEDIA_ATLAS_ALLOWED_BROWSE_ROOTS=/media

# Scanner settings.
MEDIA_ATLAS_SCAN_CONCURRENCY=2
MEDIA_ATLAS_FFPROBE_TIMEOUT_SECONDS=60
MEDIA_ATLAS_MARK_MISSING_FILES=true

# Transcode settings.
# 0 means no global ffmpeg timeout.
MEDIA_ATLAS_FFMPEG_TIMEOUT_SECONDS=0
MEDIA_ATLAS_TRANSCODE_DURATION_TOLERANCE_SECONDS=3
MEDIA_ATLAS_TRANSCODE_DURATION_TOLERANCE_PERCENT=0.02
MEDIA_ATLAS_TRANSCODE_MIN_FREE_BYTES=1073741824
MEDIA_ATLAS_READINESS_MIN_FREE_BYTES=268435456
# The example Compose file mounts ./transcode-backups to /app/transcode-backups
# as backup storage beside transcode-staging.

# Directory browser.
MEDIA_ATLAS_DIRECTORY_BROWSER_ENABLED=true

# Retention.
# Staged output retention is disabled by default so completed outputs are not
# removed unexpectedly. Quarantined partial retry outputs are removed only when
# this value is greater than 0.
MEDIA_ATLAS_LOG_RETENTION_DAYS=30
MEDIA_ATLAS_STAGED_OUTPUT_RETENTION_DAYS=0

# Optional Plex defaults. You can also configure Plex from the Settings page.
# MEDIA_ATLAS_PLEX_URL=http://192.168.1.106:32400
# MEDIA_ATLAS_PLEX_TOKEN=replace-with-plex-token

# Optional: if you customize docker-compose.yml to mount staged outputs somewhere
# other than ./transcode-staging, set that host path here.
# MEDIA_ATLAS_TRANSCODE_OUTPUT_ROOT=/mnt/media-transcode-staging

# Optional hardware transcoding requires docker-compose.yml changes:
# - VAAPI / Intel Quick Sync on Linux: mount /dev/dri
# - NVIDIA NVENC: install NVIDIA Container Toolkit and set gpus: all
LIBVA_DRIVER_NAME=iHD

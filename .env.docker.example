# Host port to expose the app on.
MEDIA_ATLAS_PORT=8000

# Host media root mounted read-only into the container at /media.
# Change this to wherever your media lives on the Docker host.
MEDIA_ATLAS_MEDIA_ROOT=/mnt/media

# In-container roots the app is allowed to browse.
# Keep these aligned with the container mount paths, not host paths.
MEDIA_ATLAS_ALLOWED_BROWSE_ROOTS=/media

# Scanner defaults.
MEDIA_ATLAS_SCAN_CONCURRENCY=2
MEDIA_ATLAS_FFPROBE_TIMEOUT_SECONDS=60

# 0 means no global ffmpeg timeout.
MEDIA_ATLAS_FFMPEG_TIMEOUT_SECONDS=0
